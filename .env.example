# SentinelCore — Environment Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before running docker compose.
#
#   cp .env.example .env
#
# The .env file is gitignored — never commit it with real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Kafka ─────────────────────────────────────────────────────────────────────
SENTINEL_KAFKA_HOST=kafka:9092

# ── PostgreSQL ────────────────────────────────────────────────────────────────
SENTINEL_DB_HOST=postgres
SENTINEL_DB_PORT=5432
SENTINEL_DB_USER=sentinel
SENTINEL_DB_PASSWORD=sentinel_pass
SENTINEL_DB_NAME=sentinel_db
SENTINEL_DB_POOL_MAX=20
SENTINEL_INSERT_BATCH_SIZE=1000

# ── Shared secret ─────────────────────────────────────────────────────────────
# REQUIRED — generate with:  openssl rand -hex 32
# Must match the value configured on every collector agent.
SENTINEL_COLLECTOR_SECRET=REPLACE_WITH_OUTPUT_OF_openssl_rand_hex_32

# ── API server ────────────────────────────────────────────────────────────────
SENTINEL_ENV=production
# CORS: comma-separated allowed origins. Set to your frontend URL in production.
SENTINEL_API_CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Firebase Auth ─────────────────────────────────────────────────────────────
# Set to true and provide a real service account path to enable token verification.
# The path is relative to INSIDE the Docker container (mount the key file via a volume).
SENTINEL_FIREBASE_AUTH_ENABLED=false
SENTINEL_FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase-key.json

# ── Frontend image (used by the frontend compose service) ─────────────────────
# Overridden automatically by the CD pipeline.
REGISTRY=ghcr.io
IMAGE_NAME=your-github-org/sentinelcore
IMAGE_TAG=latest
FRONTEND_PORT=80
